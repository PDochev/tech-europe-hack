# Copy to .env.local and fill in the blanks. Never commit .env.local.

# --- Attio (CRM) ---
# Workspace settings → Developers → New access token
ATTIO_API_KEY=
# Custom object slug for the deal pipeline (optional; defaults to "ac_deals")
ATTIO_DEALS_OBJECT=ac_deals

# --- SLNG (voice agents) ---
# https://app.slng.ai/api-keys
SLNG_API_KEY=
SLNG_AGENTS_BASE_URL=https://api.agents.slng.ai/v1
# Set after running scripts/provision-slng-agent.ts
SLNG_AGENT_ID=
# Outbound SIP trunk id from SLNG → dashboard → Telephony (required for real calls)
SLNG_OUTBOUND_TRUNK_ID=
# Region: any | us-east | eu-central | ap-south
# "any" is required for the Groq GPT-OSS model to be available on this tier.
SLNG_REGION=any
# Public base URL SLNG can reach for the book_meeting / call_end webhooks
# (ngrok in dev, your prod URL otherwise). No trailing slash.
AGENT_WEBHOOK_BASE_URL=
# Shared secret SLNG sends as a bearer token to those webhooks (required; no default)
SLNG_WEBHOOK_SECRET=
# API key required to call POST /api/agent/dispatch and /api/agent/run
# (prevents toll fraud; no default = route denies)
DISPATCH_API_KEY=
# Model ids / voice the agent uses (override the in-code defaults shown)
SLNG_AGENT_STT=slng/deepgram/nova:3-multi
SLNG_AGENT_TTS=slng/deepgram/aura:2-en
SLNG_AGENT_TTS_VOICE=aura-2-thalia-en
SLNG_AGENT_LLM=groq/openai/gpt-oss-120b:latest
# Optional toll-fraud guard: comma-separated allowed E.164 prefixes, e.g. +44,+1
ALLOWED_CALL_PREFIXES=
# Optional default caller identity used in the agent script
AGENT_CALLER_NAME=
AGENT_CALLER_COMPANY=AutoCloser

# --- Gemini / Google DeepMind ---
# https://aistudio.google.com → Get API key
GEMINI_API_KEY=
# Optional model override (defaults to the in-code value)
GEMINI_MODEL=

# --- Neon (Postgres run-state) ---
# Neon console → Connection string (pooled). Backs lib/call-store.ts (ac_calls).
DATABASE_URL=
